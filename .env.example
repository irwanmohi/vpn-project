# Copy this file to .env and fill in real values
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars

# MySQL
MYSQL_HOST=localhost
MYSQL_USER=vpnuser
MYSQL_PASSWORD=vpnpassword
MYSQL_DB=vpn_system
MYSQL_PORT=3306

# WireGuard — run `wg pubkey < /etc/wireguard/server_private.key` to get the public key
WG_INTERFACE=wg0
WG_SERVER_PUBLIC_KEY=YOUR_SERVER_WG_PUBLIC_KEY_HERE
WG_SERVER_ENDPOINT=YOUR_SERVER_PUBLIC_IP:51820
WG_DNS=1.1.1.1, 1.0.0.1
WG_CONFIG_PATH=/etc/wireguard/wg0.conf

# Defaults
DEFAULT_EXPIRY_DAYS=7

# SMTP — for expiry notification emails (leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=VPN Manager <noreply@example.com>
# Days before expiry to send the warning email
EXPIRY_WARN_DAYS=3
